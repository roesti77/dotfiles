// dev layout: main pane plus a permanent gh-dash sidebar on the first tab,
// replacing supacode's per-worktree PR sidebar. New tabs use the template
// (bar + single pane) and stay sidebar-free.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }
    tab name="dev" focus=true {
        pane
        pane size="25%" name="prs" {
            // zsh -c hardens PATH: command panes inherit the server env, which
            // may miss the homebrew path where gh lives.
            command "zsh"
            args "-c" "export PATH=/opt/homebrew/bin:$PATH; exec gh dash"
        }
    }
}
